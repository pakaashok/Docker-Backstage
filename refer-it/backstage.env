# ==========================================================
# BACKSTAGE CONFIGURATION FOR RASPBERRY PI (ARM64)
# ==========================================================

# 1. NETWORKING
# If using LibreELEC, 'libreelec.local' is the default mDNS address. 
# If they use a static IP, they should put it here (e.g., 192.168.1.50).
BASE_URL=libreelec.local

# 2. GITHUB INTEGRATION
# Your teammate must create a Classic PAT with scopes: 
# 'repo', 'workflow', 'admin:org', 'read:user'
GITHUB_TOKEN=ghp_their_new_private_token_here

# 3. POSTGRES DATABASE
# These are used by both the Backstage app and the Database container.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=backstage
POSTGRES_PASSWORD=generate_a_secure_password_here

# 4. RESOURCE OPTIMIZATION
# Since Backstage is running on a Pi, this ensures Node.js 
# doesn't try to use more than 2GB of the Pi's RAM.
NODE_OPTIONS="--max-old-space-size=2048"